# Copier ce fichier vers application-local.properties OU application-secret.properties
# pour le developpement local. Ces deux fichiers sont ignores par git.
# Ne jamais commiter de vrais secrets.

# --- Base de donnees ---
spring.datasource.username=postgres
spring.datasource.password=REMPLACER

# --- Courriel via Resend (resend.com) ---
RESEND_API_KEY=re_REMPLACER
RESEND_FROM_EMAIL=noreply@tondomaine.com
DEMO_COPY_EMAIL=ton@email.com

# --- Google OAuth (console.cloud.google.com) ---
GOOGLE_CLIENT_ID=REMPLACER.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-REMPLACER
spring.security.oauth2.client.registration.google.client-id=REMPLACER.apps.googleusercontent.com
spring.security.oauth2.client.registration.google.client-secret=GOCSPX-REMPLACER

# --- Anthropic (console.anthropic.com) ---
anthropic.api.key=sk-ant-REMPLACER

# --- Stripe (dashboard.stripe.com/test/apikeys) ---
stripe.secret-key=sk_test_REMPLACER
stripe.webhook-secret=whsec_REMPLACER
stripe.first-child-price-id=price_REMPLACER
stripe.additional-child-price-id=price_REMPLACER
stripe.first-child-monthly-amount-cents=6000
stripe.additional-child-monthly-amount-cents=4000
